# ─────────────────────────────────────────────────────────────
# BANCO DE DADOS — Supabase
# ─────────────────────────────────────────────────────────────
# URL com pgbouncer (Transaction mode) — usada pela aplicação
DATABASE_URL="postgresql://postgres:[SENHA]@db.[PROJETO].supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"

# URL direta (Session mode, porta 5432) — usada apenas pelo prisma migrate
DIRECT_URL="postgresql://postgres:[SENHA]@db.[PROJETO].supabase.co:5432/postgres"

# ─────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────
JWT_SECRET=uma_chave_secreta_muito_forte_aqui
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────
# EMAIL (Gmail — use uma "senha de app", não a senha normal)
# ─────────────────────────────────────────────────────────────
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM="EducaPlay <seu-email@gmail.com>"

# ─────────────────────────────────────────────────────────────
# RENDER — URL do seu serviço (preencha após o deploy)
# ─────────────────────────────────────────────────────────────
BASE_URL=https://educaplay-backend.onrender.com

# Porta (o Render sobrescreve automaticamente com a porta correta)
PORT=3000
