generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // DATABASE_URL com pgbouncer=true (para queries da aplicação via connection pooling)
  url       = env("DATABASE_URL")
  // DIRECT_URL sem pgbouncer (necessário para prisma migrate no Render)
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id          String   @id @default(uuid())
  nome        String
  email       String   @unique
  senha       String
  papel       String
  instituicao String?
  cargo       String?
  foto        String?
  resetToken     String?
  resetTokenExp  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  disponibilidades Disponibilidade[]
  notificacoes     Notificacao[]
}

model Professor {
  id        String   @id @default(uuid())
  nome      String
  materias  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  disponibilidades Disponibilidade[]
  aulas            Aula[]
}

model Sala {
  id         String   @id @default(uuid())
  nome       String
  capacidade String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Cronograma {
  id        String   @id @default(uuid())
  turno     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aulas Aula[]
}

model Aula {
  id           String     @id @default(uuid())
  timeStart    String
  timeEnd      String
  subject      String
  isInterval   Boolean    @default(false)
  cronogramaId String
  professorId  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  cronograma Cronograma @relation(fields: [cronogramaId], references: [id], onDelete: Cascade)
  professor  Professor? @relation(fields: [professorId], references: [id])
}

model Disponibilidade {
  id          String    @id @default(uuid())
  diaSemana   String
  turno       String
  professorId String
  usuarioId   String?
  createdAt   DateTime  @default(now())

  professor Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  usuario   Usuario?  @relation(fields: [usuarioId], references: [id])
}

model Notificacao {
  id        String   @id @default(uuid())
  titulo    String
  mensagem  String
  icon      String   @default("🔔")
  lida      Boolean  @default(false)
  usuarioId String
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}
